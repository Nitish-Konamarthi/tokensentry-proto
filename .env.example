# ═══════════════════════════════════════════════════════════
#   TOKENSENTRY — ENVIRONMENT VARIABLES
#   Copy this to .env and fill in all values
#   NEVER commit .env to git — it's in .gitignore
# ═══════════════════════════════════════════════════════════

# ── SECURITY (CRITICAL — Generate before first run) ────────
# Server-side pepper for HMAC API key hashing — 32+ chars random string
# Generate: openssl rand -base64 32
# WARNING: Never rotate this without running a key migration first
API_KEY_PEPPER=REPLACE_ME_generate_with_openssl_rand_base64_32_at_least_32_chars

# ── AI (Anthropic — Last resort only, all meta-calls use free providers) ────
# SIGN UP: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# SIGN UP: https://dash.voyageai.com → API Keys ($0.06/M tokens)
VOYAGE_API_KEY=pa-REPLACE_ME

# ── Free LLM Providers (for governance meta-calls — $0/month) ───────────────
# PRIMARY: Groq (14,400 free req/day — fastest, JSON mode)
# SIGN UP: https://console.groq.com → API Keys (Free tier)
GROQ_API_KEY=gsk_REPLACE_ME

# FALLBACK: Google Gemini Flash (1M free tokens/day)
# SIGN UP: https://aistudio.google.com → Get API Key (Free)
GEMINI_API_KEY=REPLACE_ME

# TERTIARY: Together.ai (free $1 credit on signup)
TOGETHER_API_KEY=REPLACE_ME

# ── Database (Supabase) ────────────────────────────────────
# SIGN UP: https://supabase.com → New Project → Settings → Database
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME
# NEVER expose this server-side:
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.REPLACE_ME

# ── Cache / Queue (Upstash Redis) ─────────────────────────
# SIGN UP: https://console.upstash.com → Create Database → REST API
REDIS_URL=rediss://default:REPLACE_ME@REPLACE_ME.upstash.io:6380
REDIS_PASSWORD=REPLACE_ME

# ── Analytics (ClickHouse Cloud) ──────────────────────────
# SIGN UP: https://clickhouse.cloud → New Service → Free Dev
CLICKHOUSE_URL=https://REPLACE_ME.clickhouse.cloud:8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASS=REPLACE_ME
CLICKHOUSE_DB=tokensentry

# ── Auth (Auth0) ──────────────────────────────────────────
# SIGN UP: https://manage.auth0.com → Applications → Create API
AUTH0_DOMAIN=tokensentry.us.auth0.com
AUTH0_AUDIENCE=https://api.tokensentry.ai
AUTH0_CLIENT_ID=REPLACE_ME
AUTH0_CLIENT_SECRET=REPLACE_ME
# Random 64-char hex string: openssl rand -hex 32
INTERNAL_API_SECRET=REPLACE_ME_64_CHAR_HEX

# ── Email (Resend) ─────────────────────────────────────────
# SIGN UP: https://resend.com → API Keys (3,000/month free)
RESEND_API_KEY=re_REPLACE_ME
EMAIL_FROM=noreply@tokensentry.ai
EMAIL_REPLY_TO=support@tokensentry.ai

# ── Billing (Stripe) ──────────────────────────────────────
# SIGN UP: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME
# Create in Stripe Dashboard → Products → Prices
STRIPE_PRICE_BUSINESS=price_REPLACE_ME
STRIPE_PRICE_ENTERPRISE=price_REPLACE_ME

# ── Infrastructure ─────────────────────────────────────────
# SIGN UP: https://dash.cloudflare.com → Profile → API Tokens
CLOUDFLARE_API_TOKEN=REPLACE_ME
CLOUDFLARE_ACCOUNT_ID=REPLACE_ME
# For Kubernetes deploy (AWS EKS)
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
AWS_REGION=us-east-1

# ── Observability ──────────────────────────────────────────
# SIGN UP: https://sentry.io → New Project → Node.js
SENTRY_DSN=https://REPLACE_ME@oXXXXXX.ingest.sentry.io/REPLACE_ME
# SIGN UP: https://grafana.com → Cloud → Free Tier → OTLP endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic REPLACE_ME_BASE64
GRAFANA_ADMIN_PASSWORD=REPLACE_ME_STRONG_PASSWORD
OTEL_SERVICE_NAME=tokensentry-api
OTEL_RESOURCE_ATTRIBUTES=service.version=1.0.0,deployment.environment=production

# ── Communications ─────────────────────────────────────────
# SIGN UP: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_ALERTS=https://hooks.slack.com/services/REPLACE_ME
SLACK_WEBHOOK_REVENUE=https://hooks.slack.com/services/REPLACE_ME
# SIGN UP: https://app.intercom.com → Settings → API Keys
INTERCOM_ACCESS_TOKEN=REPLACE_ME
INTERCOM_APP_ID=REPLACE_ME

# ── Free Tools ─────────────────────────────────────────────
# MinIO (S3-compatible storage — runs in Docker)
MINIO_ROOT_USER=tokensentry
MINIO_ROOT_PASSWORD=REPLACE_ME_STRONG_PASSWORD
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=tokensentry-exports

# Meilisearch (docs search — runs in Docker)
# Generate: openssl rand -hex 32
MEILISEARCH_MASTER_KEY=REPLACE_ME_32_CHAR_HEX

# n8n (workflow automation — runs in Docker)
N8N_USER=admin
N8N_PASSWORD=REPLACE_ME_STRONG_PASSWORD

# Flagsmith (feature flags)
# SIGN UP: https://flagsmith.com → API Keys
FLAGSMITH_API_KEY=REPLACE_ME

# ── App Config ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
FRONTEND_URL=https://app.tokensentry.ai
API_URL=https://api.tokensentry.ai

# ── Feature Flags ──────────────────────────────────────────
ENABLE_SEMANTIC_CACHE=true
ENABLE_AGENTIC_GUARD=true
ENABLE_WASTE_ANALYSIS=true
ENABLE_ANOMALY_DETECTION=true
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.94
AGENTIC_LOOP_DETECTION_THRESHOLD=0.60
MAX_AGENT_TURNS_BEFORE_REVIEW=30

# ── Limits & Defaults ──────────────────────────────────────
DEFAULT_MONTHLY_BUDGET_USD=500
DEFAULT_ON_EXHAUSTION=downgrade
# Per-org proxy rate limit (requests per minute per API key)
RATE_LIMIT_PROXY_ORG=500
# Per-IP proxy rate limit (requests per minute per IP)
RATE_LIMIT_PROXY_IP=100
RATE_LIMIT_API_RPS=300
RATE_LIMIT_AUTH_RPM=10
MAX_PROMPT_CHARS=131072
